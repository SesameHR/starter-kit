# Required: 32+ character secret for encrypting session cookies
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-32-char-string-at-least

# Optional: unique cookie name per app (avoids session conflicts in dev)
# SESSION_COOKIE_NAME=sesame-session

# Optional: OAuth (SSO) login — leave empty to disable the "Sign in with Sesame SSO" button
# All three vars are required when enabling OAuth.
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
# SSO_BASE_URL=https://sso.sesametime.com

# Optional: push notification application ID (required for sdk.notifications.sendPush)
# SESAME_APPLICATION_ID=your-app-id

# Optional: Cowork embed (launch ticket) — set both to run this app embedded in
# the Cowork Apps hub with single sign-on. COWORK_BACKEND_URL is the Cowork API
# origin (no trailing slash); LAUNCH_SHARED_SECRET is the per-app secret stored
# on the app's external_apps row (sent as X-Launch-Secret on the redeem call).
# Leave both empty to disable embedding — /api/auth/launch then falls back to login.
# COWORK_BACKEND_URL=https://api-cowork.sesametime.com
# LAUNCH_SHARED_SECRET=your-per-app-shared-secret
